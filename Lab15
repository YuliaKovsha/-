        private void button6_Click(object sender, EventArgs e)
        {
            string текстN = textBox10.Text;

            int n = Convert.ToInt32(текстN);

            double[] X = new double[n];
            double[] Y = new double[n];

            for (int i = 0; i < n; i++)
            {
                string координатаX = Microsoft.VisualBasic.Interaction.InputBox("Введіть X для точки " + (i + 1), "Введення координат");
                string координатаY = Microsoft.VisualBasic.Interaction.InputBox("Введіть Y для точки " + (i + 1), "Введення координат");

                X[i] = Convert.ToDouble(координатаX);
                Y[i] = Convert.ToDouble(координатаY);
            }

            double максимальнаВідстань = 0;
            int першаТочка = 0;
            int другаТочка = 0;

            for (int i = 0; i < n; i++)
            {
                for (int j = i + 1; j < n; j++)
                {
                    double різницяX = X[i] - X[j];
                    double різницяY = Y[i] - Y[j];

                    double квадратX = різницяX * різницяX;
                    double квадратY = різницяY * різницяY;

                    double відстань = Math.Sqrt(квадратX + квадратY);

                    if (відстань > максимальнаВідстань)
                    {
                        максимальнаВідстань = відстань;
                        першаТочка = i + 1;
                        другаТочка = j + 1;
                    }
                }
            }

            label16.Text = "Найбільша відстань між точкою " + першаТочка + " і точкою " + другаТочка;
            label17.Text = "Відстань = " + максимальнаВідстань;
        }

        private void button8_Click(object sender, EventArgs e)
        {
            string текст = textBox11.Text;

            if (текст.EndsWith("."))
            {
                текст = текст.Remove(текст.Length - 1, 1);
            }

            char[] розділювачі = new char[] { ' ', ',', ';', ':', '!', '?' };

            string[] слова = текст.Split(розділювачі);

            listBox3.Items.Clear();
            listBox3.Items.Add("Слова з трьох букв:");

            for (int i = 0; i < слова.Length; i++)
            {
                string слово = слова[i];

                if (слово.Length == 3)
                {
                    bool тількиБукви = true;

                    for (int j = 0; j < слово.Length; j++)
                    {
                        char символ = слово[j];

                        if (!char.IsLetter(символ))
                        {
                            тількиБукви = false;
                        }
                    }

                    if (тількиБукви == true)
                    {
                        listBox3.Items.Add(слово);
                    }
                }
            }
        }

