        private void button1_Click(object sender, EventArgs e)
        {
            string текстX = textBox1.Text;
            string текстY = textBox2.Text;

            double x = Convert.ToDouble(текстX);
            double y = Convert.ToDouble(текстY);

            double корінь = Math.Sqrt(Math.Abs(x));

            double знаменник = x + (x * x / 4);

            double вираз1 = y - корінь;
            double вираз2 = x - y / знаменник;

            double добуток = вираз1 * вираз2;

            double модуль = Math.Abs(добуток);

            double результат = Math.Log(модуль);

            label3.Text = "Результат: " + результат;
        }

